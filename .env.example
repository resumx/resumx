# Cloudflare Turnstile (https://dash.cloudflare.com → Turnstile → Add site)
# Leave empty in development to skip verification
TURNSTILE_SECRET_KEY=

# Vercel AI Gateway (https://vercel.com/docs/ai-gateway)
# Create a key at https://vercel.com/dashboard → AI Gateway → API Keys
AI_GATEWAY_API_KEY=
# AI model for converting uploaded resumes (PDF, DOCX, etc.) to Resumx Markdown
RESUME_TO_RESUMX_MARKDOWN_MODEL=

# Public site key for Turnstile widget (used in client-side code)
VITE_TURNSTILE_SITE_KEY=
