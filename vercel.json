{
	"devCommand": "cd docs && pnpm run codegen && pnpm exec vitepress dev . --port $PORT",
	"buildCommand": "pnpm docs:build",
	"outputDirectory": "docs/.vitepress/dist",
	"functions": {
		"api/convert.ts": {
			"maxDuration": 30
		},
		"api/preview.ts": {
			"maxDuration": 15,
			"includeFiles": "{styles/**,assets/icons/**,node_modules/**/lightningcss-linux-x64-gnu/**,node_modules/**/lightningcss-linux-x64-musl/**}"
		}
	}
}
