{
	"name": "@resumx/resumx",
	"version": "0.2.0",
	"homepage": "https://resumx.dev",
	"bugs": {
		"url": "https://github.com/resumx/resumx/issues"
	},
	"description": "Markdown resume builder",
	"type": "module",
	"main": "dist/index.js",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"types": "./dist/index.d.ts",
	"bin": {
		"rmx": "dist/index.js",
		"resumx": "dist/index.js"
	},
	"files": [
		"dist",
		"styles",
		"templates",
		"assets",
		"CHANGELOG.md"
	],
	"scripts": {
		"build": "pnpm run generate:style-options && tsc",
		"dev": "tsc --watch",
		"test": "vitest run",
		"test:related": "vitest related --run",
		"test:changed": "vitest run --changed",
		"test:coverage": "vitest run --coverage",
		"test:watch": "vitest",
		"lint": "tsc --noEmit",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"prepublishOnly": "rm -rf dist && pnpm run build",
		"prepare": "husky",
		"docs:dev": "pnpm --filter @resumx/docs dev",
		"docs:build": "pnpm --filter @resumx/docs build",
		"docs:preview": "pnpm --filter @resumx/docs preview",
		"deps": "madge --extensions ts,tsx --exclude '\\.(d\\.ts|test\\.(ts|tsx)|spec\\.(ts|tsx))$' --image deps.svg src/ && madge --extensions ts,tsx --exclude '\\.(d\\.ts|test\\.(ts|tsx)|spec\\.(ts|tsx))$' --json src/ > deps.json",
		"generate:style-options": "pnpm exec tsx scripts/generate-style-options.ts",
		"generate:playground-pdf": "pnpm exec tsx scripts/generate-playground-default-pdf.ts",
		"optimize-icons": "pnpm exec tsx scripts/optimize-icons.ts",
		"changelog": "conventional-changelog -p angular -i CHANGELOG.md -s"
	},
	"keywords": [
		"resume",
		"cv",
		"markdown",
		"pdf",
		"html",
		"docx",
		"cli",
		"resume-builder",
		"tailwindcss"
	],
	"license": "Apache-2.0",
	"repository": {
		"type": "git",
		"url": "https://github.com/resumx/resumx"
	},
	"author": "Yat Fu Chan",
	"packageManager": "pnpm@10.30.3",
	"engines": {
		"node": ">=20"
	},
	"dependencies": {
		"@iconify/types": "^2.0.0",
		"@iconify/utils": "^3.1.0",
		"@mdit/plugin-dl": "^0.22.3",
		"@mdit/plugin-mark": "^0.22.2",
		"@mdit/plugin-sub": "^0.23.1",
		"@mdit/plugin-sup": "^0.23.1",
		"@tailwindcss/node": "^4.1.18",
		"chalk": "^5.3.0",
		"chokidar": "^3.6.0",
		"chrono-node": "^2.9.0",
		"cities.json": "^1.1.50",
		"commander": "^12.1.0",
		"dedent": "^1.7.1",
		"fastest-levenshtein": "^1.0.16",
		"gray-matter": "^4.0.3",
		"js-beautify": "^1.15.4",
		"linkedom": "^0.18.12",
		"markdown-it": "^14.1.1",
		"markdown-it-attrs": "^4.3.1",
		"markdown-it-emoji": "^3.0.0",
		"playwright": "^1.58.0",
		"posthog-node": "^5.28.1",
		"smol-toml": "^1.6.0",
		"svgo": "^4.0.1",
		"tailwindcss": "^4.1.18",
		"which": "^6.0.1",
		"yaml": "^2.8.2",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@mdit/helper": "^0.23.1",
		"@types/js-beautify": "^1.14.3",
		"@types/markdown-it": "^14.1.2",
		"@types/markdown-it-attrs": "^4.1.3",
		"@types/node": "^25.5.0",
		"@types/which": "^3.0.4",
		"@vitest/coverage-v8": "^4.1.1",
		"conventional-changelog-cli": "^5.0.0",
		"execa": "^9.5.2",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"madge": "^8.0.0",
		"prettier": "^3.8.1",
		"tmp-promise": "^3.0.3",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"vitest": "^4.1.1"
	},
	"lint-staged": {
		"*": [
			"tsx scripts/check-windows-compat.ts"
		],
		"*.{ts,js,json,css,md}": [
			"prettier --write"
		],
		"assets/icons/*.svg": [
			"svgo --config svgo.config.mjs"
		],
		"styles/common/base.css": [
			"pnpm run generate:style-options",
			"git add src/core/style-options.generated.ts schemas/style-options.schema.json"
		],
		"docs/**": [
			"pnpm --filter @resumx/docs build"
		]
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild",
			"sharp"
		],
		"overrides": {
			"minimatch": ">=10.2.3",
			"ajv": ">=8.18.0",
			"undici": ">=6.23.0",
			"path-to-regexp": ">=6.3.0",
			"rollup": ">=4.59.0",
			"@conventional-changelog/git-client": ">=2.0.0",
			"esbuild": ">=0.25.0"
		}
	}
}
