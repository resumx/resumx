{
	"name": "resum8",
	"version": "0.1.0",
	"description": "Minimal markdown resume builder with beautiful PDF output",
	"type": "module",
	"main": "dist/index.js",
	"bin": {
		"m8": "dist/index.js",
		"resum8": "dist/index.js"
	},
	"files": [
		"dist",
		"styles",
		"templates"
	],
	"scripts": {
		"build": "tsc",
		"dev": "tsc --watch",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "tsc --noEmit",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"prepublishOnly": "npm run build",
		"prepare": "husky"
	},
	"keywords": [
		"resume",
		"cv",
		"markdown",
		"pdf",
		"cli"
	],
	"author": "",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/yatfuchan/resum8"
	},
	"engines": {
		"node": ">=20"
	},
	"dependencies": {
		"chalk": "^5.3.0",
		"chokidar": "^3.6.0",
		"commander": "^12.1.0"
	},
	"devDependencies": {
		"@types/node": "^22.0.0",
		"execa": "^9.5.2",
		"husky": "^9.1.7",
		"lint-staged": "^16.2.7",
		"prettier": "^3.8.1",
		"tmp-promise": "^3.0.3",
		"typescript": "^5.7.0",
		"vitest": "^2.1.0"
	},
	"lint-staged": {
		"*.{ts,js,json,css,md}": [
			"prettier --write"
		]
	}
}
